# Copy to .env and fill in values.

# openai | anthropic
LLM_PROVIDER=openai

# --- OpenAI (GPT-4o / GPT-4o-mini vision) ---
# Required if LLM_PROVIDER=openai (missing key -> 503 on /analyze-error)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Anthropic (Claude 3.5 Sonnet vision) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Max upload size in bytes (default 15 MB if unset)
MAX_IMAGE_BYTES=15728640

# Comma-separated browser origins for Expo dev / web (add your production web origin when deployed)
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006,http://localhost:8082,http://127.0.0.1:8082
